#!/usr/bin/perl

# docker-event-daemon
#
# A daemon that keeps Dockside's container state file (containers.json) in sync with the live
# Docker engine, bridging Docker's runtime state to Dockside's own data layer so the application
# always has an up-to-date view of running containers.
#
# Event loop (eventHandler):
# - Spawns `docker events --format "{{ json . }}"` as a subprocess.
# - Uses IO::Async to process each event line as JSON in a non-blocking loop.
# - Runs a 0.5s periodic timer alongside the event stream.
#
# Debounced updates (timer tick):
# Three tiers of update frequency:
# 1. With sizes    - every ~55s, but only when no events have arrived for 5+ seconds (slow, so deferred).
# 2. After events  - within 1s of a relevant event (fast refresh).
# 3. Heartbeat     - every 15s regardless (keeps state fresh even when idle).
#
# Event handling (onEvent):
# Listens for specific Docker event types:
# - network connect/disconnect     -> triggers a container update.
# - container stop/create/destroy  -> triggers a container update.
# - container start                -> triggers onContainerStart, which also launches the IDE
#                                     process inside the container via $reservation->exec().
#
# Container state update (_update / update):
# - Calls the Docker API (/containers/json) via a Unix socket.
# - Rebuilds the container map: short ID, name, status, image, ports, volume mounts
#   (including the IDE volume path and host-data volume path).
# - Preserves the last-known Size value when not requesting a fresh size calculation (avoiding slow calls).
# - Writes results to containers.json via cacheReadWrite.
# - Triggers Reservation->load_clean_map to assign expiry times to reservations
#   whose containers have disappeared.
#
# Lifecycle:
# - Runs in an outer while(1) loop: if eventHandler crashes or the docker events stream closes,
#   it restarts automatically after 1 second.
# - Handles SIGTERM/SIGINT/SIGQUIT cleanly: sets a flag, stops the IO loop, terminates the
#   docker events subprocess (SIGTERM then SIGKILL if needed), and exits.

use v5.36;

use JSON;

use Try::Tiny;
use File::Path;
use IO::Handle;
use IO::Select;
use IPC::Open2 qw(open2);
use Time::HiRes qw(time);
use URI::Escape;

use IO::Async::Loop;
use IO::Async::Protocol::LineStream;
use IO::Async::Timer::Periodic;

use Util qw(cacheReadWrite flog call_socket_api run_system unique);
use Exception;
use Data qw($CONFIG);
use Reservation;
use Containers;
use User;

my $SIGNAL_RECEIVED = 0;
my $STOP_EVENT_LOOP = sub { };

$SIG{'INT'} = $SIG{'QUIT'} = $SIG{'TERM'} = sub {
   # This will interrupt can_read()/stop IO::Async loop.
   flog("eventHandler: Received SIGTERM; preparing to exit.");
   $SIGNAL_RECEIVED = 1;
   $STOP_EVENT_LOOP->();
};

# Updates the container state by retrieving the current container list
# from the Docker API and merging it with the existing container data.
#
# Parameters:
# - $oldJSON: A JSON string representing the previous state of the containers.
# - $opts: A hash reference containing options, specifically
#   - 'updateSizes' => undef|1
#     whether to include container sizes in the API request.
#
# Returns:
# A JSON string representing the updated container state, including
# both the existing and newly retrieved container data.
#
# Throws:
# Exception if unable to retrieve the container list from the Docker API
# or if the API response is not successful.

sub _update ($oldJSON, $opts) {
   # $CONFIG->{'docker'}{'sizes'} can disable size tracking entirely, not just defer it.
   my $path = '/containers/json?all=true' . (($CONFIG->{'docker'}{'sizes'} && $opts->{'updateSizes'}) ? '&size=true' : '');

   flog("update: requesting container list" . ($opts->{'updateSizes'} ? ' with sizes' : ' without sizes'));

   my $result = call_socket_api(
      $CONFIG->{'docker'}{'socket'},
      $path
   );

   unless($result) {
      die Exception->new( 'dbg' => "Unable to execute Docker API call: $path #1", 'msg' => "Unable to retrieve container list" );
   }

   if(!$result->is_success) {
      die Exception->new( 'msg' => sprintf("Unable to obtain container list via $path (response code %d, error '%s')", $result->code, $result->message) );
   }

   my $newContainersFromAPI;
   my $oldContainers;
   try {
      $oldContainers = $oldJSON ? decode_json($oldJSON)->{'containers'} : {};
      $newContainersFromAPI = decode_json($result->body);
   }
   catch {
      $oldContainers = {};
   };

   my $idePath = $CONFIG->{'ide'}{'path'};
   my $hostDataPath = $CONFIG->{'ssh'}{'path'};

   my $newContainers;
   foreach my $c (@$newContainersFromAPI) {

      my $ID = substr($c->{'Id'}, 0, 12); # Truncate to Docker's standard short ID length.

      # For each mount point of interest, produce ['volume', $name] or ['bind', $source].
      my ($ideVolume) = map { $_->{'Type'} eq 'volume' ? ['volume', $_->{'Name'}] : ['bind', $_->{'Source'}] } grep { $_->{'Destination'} eq $idePath } @{$c->{'Mounts'}};
      my ($hostDataVolume) = map { $_->{'Type'} eq 'volume' ? ['volume', $_->{'Name'}] : ['bind', $_->{'Source'}] } grep { $_->{'Destination'} eq $hostDataPath } @{$c->{'Mounts'}};

      $newContainers->{$ID}{'docker'} = {
         'ID' => $ID, # Short ID (for now)
         'Names' => substr($c->{'Names'}[0], 1), # Skip leading '/'
         'CreatedAt' => $c->{'Created'}, # Was string; now unixtime
         'Status' => $c->{'Status'}, # String
         'Image' => $c->{'Image'}, # String
         'ImageId' => substr( substr($c->{'ImageID'}, 7), 0, 12), # Strip 'sha256:' prefix (7 chars), then truncate to short ID.
         'Size' => $c->{'SizeRw'},
         'Networks' => join(',', sort keys %{$c->{'NetworkSettings'}{'Networks'}})
      };

      # HashRef keyed on internal port looking up host port.
      # This is only needed when $CONFIG->{'gateway'}{'enabled'} is true (and this is deprecated)
      my $ports = { map { $_->{'PrivatePort'} => $_->{'PublicPort'} } @{$c->{'Ports'}} };

      $newContainers->{$ID}{'inspect'} = { 
         'Networks' => $c->{'NetworkSettings'}{'Networks'},
         'Ports' => $ports,
         'ideVolume' => $ideVolume,
         'hostDataVolume' => $hostDataVolume
      };

      # Copy the container Size from the oldContainer record if we haven't requested the Size on this run.
      if( $oldContainers && $oldContainers->{$ID} && $oldContainers->{$ID}{'docker'}{'Size'} ) {
         if( !$newContainers->{$ID}{'docker'}{'Size'} ) {
            $newContainers->{$ID}{'docker'}{'Size'} = $oldContainers->{$ID}{'docker'}{'Size'};
         }
      }

   }

   my $newContainersFile = { 'version' => Containers::CURRENT_VERSION, 'containers' => $newContainers };

   return encode_json($newContainersFile);
}

# Updates the container state by retrieving the current container list
# from the Docker API and merging it with the existing container data.
#
# Parameters:
# - $opts: A hash reference containing options, specifically
#   - 'updateSizes' => undef|1
#     whether to include container sizes in the API request.
#
# Returns:
# A JSON string representing the updated container state, including
# both the existing and newly retrieved container data.
#
# Throws:
# Exception if unable to retrieve the container list from the Docker API
# or if the API response is not successful.
sub update ($opts = {}) {

   # cacheReadWrite handles the atomic read-modify-write cycle: it reads the existing
   # file, passes its content as $oldJSON to _update, then writes the returned JSON back.
   my $containersJSON = cacheReadWrite(
      $CONFIG->{'containersPath'},
      \&_update,
      $opts
   );

   try {
      my $containersFile = decode_json($containersJSON);
      my $containers = $containersFile->{'containers'};

      # Assign ExpiryTimes to Reservations missing containers, and clean up old Reservations.
      Reservation->load_clean_map(keys %$containers);
   }
   catch {
      flog("update: caught exception: " . (ref($_) ? $_->dbg : $_));
   };
}

# Called when a container start event is received. Updates container state, reloads all
# data files (config, users, reservations, containers), then launches the IDE process
# inside the container if it belongs to a Dockside-managed reservation.
sub onContainerStart ($id, $eventCount) {

   # This container's details might not yet have been loaded. Do this now.
   flog("onContainerStart #$eventCount: Updating docker containers without sizes before reloading reservations");
   update();

   # Reload config, reservations and containers, to access Reservation->load and %CONFIG.
   # Reload users and roles too, in case we can update owner's name and email [at later date].
   Data::load('config.json', 'users.json', 'roles.json', 'reservations.json', 'containers.json');

   my $reservations = Reservation->load({ 'containerId' => $id });
   if(!@$reservations) {
      flog("onContainerStart #$eventCount: we don't manage containerId=$id");
      return undef;
   }

   my $reservation = $reservations->[0]; # Safe: filtered by containerId, so at most one match.
   my $reservationId = $reservation->id;
   my $containerId = $reservation->containerId;

   flog("onContainerStart #$eventCount: we manage reservationId=$reservationId with containerId=$containerId");

   try {
      $reservation->exec();
   }
   catch {
      my ($msg, $dbg) = ref($_) ? ($_->msg(), $_->dbg()) : ($_,$_);
      flog("onContainerStart #$eventCount: failed to launch IDE for reservationId=$reservationId with containerId=$containerId: dbg='$dbg'; msg='$msg'");
      return undef;
   };

   return 1;
}

# Classifies a raw Docker event and dispatches to the appropriate handler.
# Returns 1 if the event is relevant (accumulated into $relevantEvents to trigger a fast
# container-state refresh), or 0 if it is not of interest and can be ignored.
sub onEvent ($event, $eventCount) {

   my $id = $event->{'Actor'}{'ID'};
   my $type = $event->{'Type'};
   my $action = $event->{'Action'};

   flog(
      sprintf("onEvent #$eventCount: received event: Type=%s, Action=%s, Actor=%s",
         $type, $action, $id
      )
   );

   if( $type eq 'network' && $action =~ /^(connect|disconnect)$/ ) {
      return 1; # Network topology changed; container port/network data may be stale.
   }

   if( $type eq 'container' && $action =~ /^(stop|create|destroy)$/ ) {
      return 1; # Container lifecycle change; state refresh needed.
   }

   if( $type eq 'container' && $action =~ /^(start)$/ ) {
      onContainerStart($id, $eventCount);
      return 1;
   }

   return 0; # Unrecognised event type/action; no update needed.
}

# Runs the main event loop: spawns 'docker events', wires up the async line reader and
# periodic timer, then blocks until the stream closes, an exception occurs, or a signal fires.
# On exit, cleans up the IO loop and terminates the subprocess gracefully.
sub eventHandler {
   flog("eventHandler: Starting...");

   my $IOHandle = IO::Handle->new();

   my $pid = open2(
      $IOHandle, undef, # undef: no stdin needed for 'docker events'.
      $CONFIG->{'docker'}{'bin'}, 'events', '--format', "{{ json . }}"
   ) || die Exception->new( 'msg' => "Unable to launch 'docker events'");

   flog("eventHandler: Launched 'docker event' subprocess with PID $pid");

   $IOHandle->autoflush(1);
   $IOHandle->blocking(0); # Non-blocking I/O required for IO::Async multiplexing.

   my $eventCount = 0;
   my $lastSizesUpdateTime = 0;
   my $lastUpdateTime = 0;
   my $lastEventTime = 0;
   my $debounceQuietPeriod = 15;
   my $debounceRelevantEventsPeriod = 1;
   my $relevantEvents = 1; # force a call to Update() on startup

   my $timeout = IO::Async::Timer::Periodic->new(
      interval => 0.5,
      on_tick => sub {
         try {
            # Updating with sizes can be slow, so only do this if:
            # - it's been more than 5s since the last event; and
            # - it's been more than 55s since the last time sizes were updated.
            if(time - $lastEventTime >= 5 && time - $lastSizesUpdateTime >= 55) {
               $lastSizesUpdateTime = time;
               flog("eventHandler:tick: updating docker containers with sizes");
               update({ 'updateSizes' => 1 });
            }
            elsif($relevantEvents && time - $lastEventTime >= $debounceRelevantEventsPeriod) {
               flog("eventHandler:tick: updating docker containers without sizes after ${debounceRelevantEventsPeriod}s after relevant events");
               $relevantEvents = 0;
               update();
            }
            elsif(time - $lastUpdateTime >= $debounceQuietPeriod) {
               $lastUpdateTime = time;
               flog("eventHandler:tick: updating docker containers without sizes after ${debounceQuietPeriod}s");
               update();
            }
         }
         catch {
            flog("eventHandler::on_tick: caught exception: " . (ref($_) ? $_->dbg : $_));
         };
      },
   );
   
   my $loop = IO::Async::Loop->new;

   my $proto = IO::Async::Protocol::LineStream->new(
      handle => $IOHandle,

      on_read_line => sub ($self, $line) {
         # $line does not include the newline
         my $event;
         eval { $event = decode_json($line); 1 } or do {
            flog("docker events: JSON decode failed: $@ ; line=[$line]");
            return;
         };

         $eventCount++;
         $lastEventTime = time;

         try {
            $relevantEvents += onEvent($event, $eventCount);
         }
         catch {
            flog("eventHandler::on_read_line #$eventCount: caught exception: " . (ref($_) ? $_->dbg : $_));
         };
      },

      on_read_eof => sub ($self) {
         flog("docker events: EOF");
         $loop->stop;
      },

      on_closed => sub ($self) {
         flog("docker events: closed");
         $loop->stop;
      },
   );

   $timeout->start;
   $loop->add($timeout);
   $loop->add($proto);
   $STOP_EVENT_LOOP = sub { $loop->stop; };

   try {
      $loop->run;
   }
   catch {
      flog("eventHandler: caught exception: " . (ref($_) ? $_->dbg : $_));
      sleep 1 unless $SIGNAL_RECEIVED; # Rate-limit crash loops; skip if we're shutting down.
   };

   # Reset to no-op so a late SIGTERM arriving after loop exit doesn't call stop on a dead loop.
   $STOP_EVENT_LOOP = sub {};
   flog("eventHandler: Ending...");
   close $IOHandle;

   flog(sprintf("eventHandler: Sending signal TERM=%d to 'docker events' subprocess PID $pid", kill(15, $pid)));
   sleep 1;
   
   if( waitpid( $pid, 0 ) == $pid ) {
      flog("eventHandler: Reaped 'docker events' subprocess PID $pid");
   }
   else {
      flog(sprintf("eventHandler: Sending signal KILL=%d to 'docker events' subprocess PID $pid", kill(9, $pid)));
   }

   flog("eventHandler: Ended.");
}

####################################################################################################

flog({ 'service' => 'docker-event-daemon', 'file' => "/var/log/$ENV{'USER'}/$ENV{'USER'}.log" });
flog("Starting...");

Data::load('config.json');

# Create temporary path needed for cache and log files.
if( ! -d $CONFIG->{'tmpPath'} ) {
   mkpath( [ $CONFIG->{'tmpPath'} ], 0, 0755 );
}

# Restart eventHandler if the 'docker events' stream closes unexpectedly (e.g. Docker restart).
while(1) {
   eventHandler();

   last if $SIGNAL_RECEIVED;
   sleep 1;
}
flog("Exiting.");

1;
